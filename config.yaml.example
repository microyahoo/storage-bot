# Storage Bot Configuration Example
# Copy this to config.yaml and fill in your values.

feishu:
  app_id: "cli_xxxxxxxxxxxx"
  app_secret: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# LLM provider configuration
# Supported providers: claude, openai, deepseek, local (ollama/vLLM)
llm:
  provider: "claude"                       # claude | openai | deepseek | local
  api_key: "sk-ant-xxxxx"                  # or set LLM_API_KEY env var
  model: ""                                # optional, auto-selected per provider
  base_url: ""                             # optional, override API endpoint

# Development / testing flags
# - disable_llm: skip LLM intent fallback + AI analysis. Replies show raw diagnostics.
# - dry_run: skip command execution. Replies show what WOULD have been executed.
# Both default to false (production mode).
dev:
  disable_llm: false
  dry_run: false

# Optional admin web UI. Leave `listen` empty to disable.
web:
  listen: ":8080"
  username: "admin"
  password: "change-me"

# --- Provider examples ---
#
# Claude (default):
#   provider: "claude"
#   api_key: "sk-ant-xxxxx"
#   model: "claude-sonnet-4-6-20250514"
#
# OpenAI:
#   provider: "openai"
#   api_key: "sk-xxxxx"
#   model: "gpt-4o"
#
# DeepSeek:
#   provider: "deepseek"
#   api_key: "sk-xxxxx"
#   model: "deepseek-chat"
#
# Local (Ollama):
#   provider: "local"
#   model: "qwen2.5:14b"
#   base_url: "http://localhost:11434/v1"

clusters:
  cluster-01:
    kubeconfig: "/etc/storage-bot/kubeconfigs/cluster-01"
    namespace: "rook-ceph"           # optional, default: rook-ceph
    toolbox_pod: "rook-ceph-tools"   # optional, default: rook-ceph-tools

    # server_override replaces the apiserver URL embedded in the kubeconfig.
    # Required when the kubeconfig was generated with 127.0.0.1 (kubeadm default)
    # or an internal DNS name that the storage-bot pod cannot resolve/reach.
    # Set this to the apiserver address reachable from where the bot runs:
    #   - the master node IP, with apiserver listening externally
    #   - a LoadBalancer IP / NodePort
    #   - a VPN-internal address
    server_override: "https://10.0.1.10:6443"

    # Skip apiserver TLS verification. Use only when server_override points to an
    # address not in the apiserver cert SANs. Prefer regenerating the cert with
    # the right SANs instead of skipping verification.
    insecure_skip_tls_verify: false

    gateway_node:              # 只配这一个
        name: "node-1"
        host: "10.0.1.1:22"
        user: "root"
        key_file: "/root/.ssh/id_rsa"          # bot 本地的密钥，连 gateway 用
        gateway_key_file: "/root/.ssh/id_rsa"  # gateway 上的密钥路径，连其他节点用
    ssh_nodes: # ssh_nodes 可以不配，也可以配来覆盖自动发现结果
      - name: "node-1"
        host: "10.0.1.1:22"
        user: "root"
        key_file: "/etc/storage-bot/ssh/id_rsa"
      - name: "node-2"
        host: "10.0.1.2:22"
        user: "root"
        key_file: "/etc/storage-bot/ssh/id_rsa"

  cluster-02:
    kubeconfig: "/etc/storage-bot/kubeconfigs/cluster-02"
    server_override: "https://10.0.2.10:6443"
    gateway_node:
        name: "node-1"
        host: "10.0.2.1:22"
        user: "root"
        key_file: "/root/.ssh/id_rsa"          # bot 本地的密钥，连 gateway 用
        gateway_key_file: "/root/.ssh/id_rsa"  # gateway 上的密钥路径，连其他节点用

rest_storages:
    yrfs01:                                      # 焱融云文件存储 (YRFS)
      base_url: "https://192.168.73.25"
      username: "admin"
      password: "Passw0rd"
